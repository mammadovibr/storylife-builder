{
  "name": "storylife-builder",
  "version": "0.1.0",
  "private": true,
  "description": "StoryLife Builder v0.1 - node-based editor for interactive text games.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev": "node scripts/dev.cjs",
    "build": "node scripts/build-app.cjs && node scripts/build-player.cjs && tsc -p electron/tsconfig.json",
    "build:ipad": "node scripts/build-ipad.cjs",
    "verify:ipad": "node scripts/verify-ipad-build.cjs",
    "build:win": "set ELECTRON_CACHE=.electron-cache&& set ELECTRON_BUILDER_CACHE=.electron-builder-cache&& set CSC_IDENTITY_AUTO_DISCOVERY=false&& node scripts/build-app.cjs && node scripts/build-player.cjs && tsc -p electron/tsconfig.json && electron-builder --win nsis",
    "test": "vitest run"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pageflip": "^2.0.3",
    "reactflow": "^11.11.4",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.storylife.builder",
    "productName": "StoryLife Builder",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "esbuild@0.25.12": true,
    "esbuild@0.21.5": true
  }
}
